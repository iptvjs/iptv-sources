d_serial":"0","vod_tv":"","vod_weekday":"","vod_area":"美国","vod_lang":"英语","vod_year":"2024","vod_version":"","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":121,"vod_hits_day":274,"vod_hits_week":813,"vod_hits_month":320,"vod_duration":"98","vod_up":984,"vod_down":979,"vod_score":"10.0","vod_score_all":6220,"vod_score_num":622,"vod_time":"2026-03-21 18:21:38","vod_time_add":1774088468,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":0,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p><span style=\"color: rgb(17, 17, 17); font-family: Helvetica, Arial, sans-serif; font-size: 13px; background-color: rgb(255, 255, 255);\">米娅是一名年轻的记者，她和一群年轻的企业家和影响者参加了一场名为“如何在 48 小时内获得 100 万粉丝”的激励研讨会，该研讨会由演讲者和教练塞巴斯蒂安·克拉夫特主持。房间里挤满了 50 人，所有人都积极向上，想要进一步提升自己、提升自己的数字形象和业务。研讨会第一天结束后，有一个庆功宴，所有影响者都试图用无数的自拍和自拍故事来超越彼此。研讨会的第二天是一场专注的大师班，由 8 位想要获得高级见解的影响者预订。这 8 位影响者中的一些人试图让塞巴斯蒂安分享一些关于如何成功的更多秘密。当他提到黑魔法和女巫时，听众们都很好奇。他声称要咨询住在房子附近的女巫。这个女巫可以让你立刻成为著名的社交媒体明星。对名声的渴望压倒了这群人的恐惧，不久之后，这群由 8 名被迷惑的网红组成的团队出发去寻找女巫，以支付她的服务费用，从而获得权力和名声。这群人找到了女巫，但他们也发现了很多他们不想要的东西。这部黑暗恐怖喜剧展开了一场生存游戏，并揭示了每个角色的真实本性。这部电影不断跨越自爱和不健康的自恋之间的界限，唯一的问题是谁能活过这个夜晚。<\/span><\/p>","vod_play_from":"snm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD$https:\/\/v14.yuglf.com\/202603\/21\/7UuUiQBmfM19\/video\/index.m3u8","vod_down_from":"","vod_down_server":"","vod_down_note":"","vod_down_url":"","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"喜剧片"},{"vod_id":142045,"type_id":7,"type_id_1":1,"group_id":0,"vod_name":"河狸变身计划","vod_sub":"狸想奇兵(港) \/ 狸想世界(台) \/ 跃动世界","vod_en":"helibianshenjihua","vod_status":1,"vod_letter":"H","vod_color":"","vod_tag":"","vod_class":"美国,喜剧","vod_pic":"http