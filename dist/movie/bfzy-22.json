门黑道大姐大，打戏必不可少，动作的部分也将由她自己独立完成，虽然打戏还未正式开拍，但是她内心已是非常期待。","vod_play_from":"bfzym3u8","vod_play_server":"","vod_play_note":"","vod_play_url":"HD$https:\/\/s1.fengbao9.com\/video\/feichangjiaoyi\/HD\/index.m3u8","vod_down_from":"","vod_down_server":"","vod_down_note":"","vod_down_url":"","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"喜剧片"},{"vod_id":148629,"type_id":22,"type_id_1":20,"group_id":0,"vod_name":"夜王","vod_sub":"Night King \/ 夜王(导演版)","vod_en":"yewang","vod_status":1,"vod_letter":"Y","vod_color":"","vod_tag":"","vod_class":"喜剧","vod_pic":"https:\/\/img.picbf.com\/upload\/vod\/20260620-1\/55eafd62707ac576b59f26add66a48b7.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":"","vod_actor":"黄子华 , 郑秀文 , 王丹妮 , 廖子妤 , 杨伟伦 , 谢君豪 , 卢镇业 , 何启华 , 杨偲泳 , 谭旻萱 , 李芯駖 , 林熙彤 , 邓丽英 , 蔡蕙琪 , 黄洁琪 , 赵君瑜 , 王紫影 , 黎纪君 , 董玮 , 甄懋强 , 许素莹 , 张可坚 , 徐浩昌 , 陈献略 , 邱颂伟 , 苏民峰 , 麦子云 , 廖颖琛","vod_director":"吴炜伦","vod_writer":"","vod_behind":"","vod_blurb":"尖东“夜场传奇”欢哥（黄子华 饰）万万没想到，中年最大危机是被收购，空降新上司竟是自己的霸道前妻V姐（郑秀文 饰）。前妻变上司，夜场秒变修罗场，欢哥和团队成员为保饭碗，花招频出，却发现背后是更大的资本收割棋局。夜场灭灯在即，昔日冤家从“互怼”变“盟友”，与东日仝人使出浑身离谱解数，誓与资本硬杠到底！一场爆笑逆袭之战，即将开打......","vod_remarks":"更新至HD","vod_pubdate":"","vod_total":0,"vod_serial":"0","vod_tv":"","vod_weekday":"","vod_area":"中国大陆 \/ 中国香港","vod_lang":"粤语 \/ 汉语普通话","vod_year":"2026","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":165,"vod_hits_day":718,"vod_hits_week":239,"vod_hits_month":98,"vod_duration":"","vod_up":612,"vod_down":254,"vod_score":"4.0","vod_score_all":1804,"vod_score_num":451,"vod_time":"2026-06-20 13:46:42","vod_time_add":1781934398,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":37375594,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_