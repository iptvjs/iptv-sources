d_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":27605659,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>1945年抗战胜利前夕，侵华日军第七三一部队在哈尔滨平房区以“给水防疫”为名，秘密进行惨无人道的细菌战研究，大肆抓捕平民进行活体实验，妄图以此扭转败局。小贩王永章（姜武 饰）等人被强行抓入“特设监狱”，日军以“配合健康检查与防疫研究即可换取自由”的虚伪承诺，欺骗他们遭受冻伤实验、毒气实验、活体解剖等极端折磨……                                    <br\/>　　影片通过平民视角揭露日军反人类暴行，展现绝境下国人不屈的反抗精神，旨在让世人铭记历史，勿忘国耻，捍卫和平。<\/p>","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn31.com\/20251218\/845_caac6bd8\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20251218\/845_caac6bd8\/731 (2025).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"战争片"},{"vod_id":119720,"type_id":12,"type_id_1":1,"group_id":0,"vod_name":"双塔英雄","vod_sub":"","vod_en":"shuangtayingxiong","vod_status":1,"vod_letter":"S","vod_color":"","vod_tag":"","vod_class":"历史,战争","vod_pic":"https:\/\/viptulz.com\/upload\/vod\/20251208-1\/855d28c0b8dac6197d3339ee1dfe9e6f.jpg","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":"","vod_actor":"胡晓刚,郭立武,付子豪,赵雨蒙,夏梦,杨春艳","vod_director":"蔡青","vod_writer":"","vod_behind":"","vod_blurb":"影片以1945年抗日战争末期为背景，讲述冀热辽军区为配合苏联红军反攻承德，派出连长张峻接任双塔山游击区区队长，开展里应外合作战的故事。张峻到任前，因地主闫世昌勾结日伪，游击队屡遭重创，前队长赵山林牺牲","vod_remarks":"HD","vod_pubdate":"2025-12-01","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"大陆","vod_lang":"国语","vod_year":"2025","vod_version":"","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":0,"vod_hits_day":0,"vod_hits_week":0,"vod_hits_month":0,"vod_duration":"","vod_up":0,"vod_down":0,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2025-12-08 05:35:03","vod_time_add":1765143303,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":37895794,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>影片以1945年抗日战争末期为背景，讲述冀热辽军区为配合苏联红军反攻承德，派出连长张峻接任双塔山游击区区队长，开展里应外合作战的故事。张峻到任前，因地主闫世昌勾结日伪，游击队屡遭重创，前队长赵山林牺牲，根据地濒临失守。张峻在上任途中智擒伪军队长吴德全，迫使其据点缴械，获一批武器，缓解了游击队的装备短缺。随后，他联合村长林江、妇教会主任春玲等人，重整队伍，并结识原鸡冠山头目冯佳吉。冯因与闫世昌有旧仇，一心报仇，后与张峻合作歼敌。张峻利用闫世昌强娶赵山林之女赵佳慧之机设伏，歼灭日伪数人，佳慧亲手击毙杀父仇人日军军官小林，冯佳吉也手刃闫世昌。<\/p>","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn31.com\/20251207\/564_00249140\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20251207\/564_00249140\/双塔英雄 (2025).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"战争片"},{"vod_id":118975,"type_id":12,"type_id_1":1,"group_id":0,"vod_name":"生还2025","vod_sub":"Survival","vod_en":"shenghuan2025","vod_status":1,"vod_letter":"S","vod_color":"","vod_tag":"","vod_class":"剧情,战争","vod_pic":"https:\/\/viptulz.com\/upload\/vod\/20251201-1\/2c4eb1189a7e9454429cf7c43268818c.jpg","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":"","vod_actor":"邵正一,周思羽,周云鹏,彭禺厶,徐励,邱健,侯佳音,徐雅惠,刘頔,李昕廷 ,王天心 ,李梦瑶,梁颂晴,段秋钰,景天曈,寇文琦,刘政杰,朱宏嘉,曹卫宇,马国伟,杨奇鸣,逯长恩,苗博,郑好,张宏威,叶福生,何熙维,王俏,翟赫","vod_director":"高群书,肖一凡","vod_writer":"某小丫,高群书,高阳","vod_behind":"","vod_blurb":"本片以纪实风格再现了1938年到1945年抗日联军第六军被服厂女兵，伤兵医院伤兵组成的留守团在主力部队西征后坚持在老游击区牵制敌人主力，于重重围剿中突围，进入苏联整训，整编为抗联第88教导旅打回东北的","vod_remarks":"HD","vod_pubdate":"2025-09-03","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"大陆","vod_lang":"国语","vod_year":"2025","vod_version":"","vod_state":"正片","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyr