s:\/\/img.picbf.com\/upload\/vod\/20260501-1\/71f75c1cf4136309740ce228bd8906ce.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":"","vod_actor":"海利·金 , Chase Ramsey , Austin Archer , Lindsay Foster","vod_director":"Chris Copier","vod_writer":"","vod_behind":"","vod_blurb":"研究近东古代神话的年轻学者艾拉，在古董店购得一尊神秘陶罐后，家中接连遭遇诡异事件：物品莫名移位、深夜听见低语、家庭成员出现幻觉与精神崩溃。随着调查深入，她发现陶罐封印着古代美索不达米亚神话中的灾厄“拉比苏（Rabisu）”—— 这是一种以恐惧、精神错乱为食的无形恶魔。拉比苏不直接血腥杀戮，而是通过侵蚀心智、制造幻觉，让受害者在绝望中自我毁灭。艾拉必须在自己与家人彻底沦陷前，破解诅咒本源，驱散这只来自远古的恶魔。","vod_remarks":"更新至HD","vod_pubdate":"","vod_total":0,"vod_serial":"0","vod_tv":"","vod_weekday":"","vod_area":"美国","vod_lang":"英语","vod_year":"2026","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":849,"vod_hits_day":349,"vod_hits_week":360,"vod_hits_month":865,"vod_duration":"","vod_up":877,"vod_down":547,"vod_score":"3.0","vod_score_all":1821,"vod_score_num":607,"vod_time":"2026-05-01 11:05:49","vod_time_add":1777604737,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":38371336,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"研究近东古代神话的年轻学者艾拉，在古董店购得一尊神秘陶罐后，家中接连遭遇诡异事件：物品莫名移位、深夜听见低语、家庭成员出现幻觉与精神崩溃。随着调查深入，她发现陶罐封印着古代美索不达米亚神话中的灾厄“拉比苏（Rabisu）”—— 这是一种以恐惧、精神错乱为食的无形恶魔。拉比苏不直接血腥杀戮，而是通过侵蚀心智、制造幻觉，让受害者在绝望中自我毁灭。艾拉必须在自己与家人彻底沦陷前，破解诅咒本源，驱散这只来自远古的恶魔。","vod_play_from":"bfzym3u8","vod_play_server":"","vod_play_note":"","vod_play_url":"HD$https:\/\/v10.baofeng10.com\/video\/labisuemodezuzhou\/feed710edf72\/index.m3u8","vod_down_from":"","vod_down_server":"","vod_down_note":"","vod_down_url":"","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"恐怖片"},{"vod_id":142717,"type_id":23,"type_id_1":20,"group_id":0,"vod_name":"恐怖藏品","vod_sub":