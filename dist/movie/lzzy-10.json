，导致她失去了头。一系列神秘事件开始困扰安巴尔和疗养院的所有居民，尤其是在他们在地下室发现一座无头雕像和一张包含恐怖歌曲的黑胶唱片之后。开斋节那天，当孤儿院的居民发现阿尼奶奶已经没有头了，事情变得更加紧张。每个人都很恐慌，尤其是当伊万娜复仇的秘密一个接一个地被揭露时。由于孤儿院所有居民的安全现在都处于危险之中，安巴尔必须在精神夺走他们的生命之前完成伊万娜的复仇。","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn27.com\/20260701\/12291_02bfd5d2\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20260701\/12291_02bfd5d2\/伊万娜 Ivanna (2022).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"恐怖片"},{"vod_id":144114,"type_id":10,"type_id_1":1,"group_id":0,"vod_name":"午夜电梯","vod_sub":"The Horror Elevator","vod_en":"wuyedianti","vod_status":1,"vod_letter":"W","vod_color":"","vod_tag":"","vod_class":"惊悚,恐怖","vod_pic":"https:\/\/img.lzipic.com\/upload\/vod\/20260629-1\/5f245ec0d1a7911aa2748b405104c45d.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":null,"vod_actor":"刘博,赵帅","vod_director":"郑来志","vod_writer":"汪宇锋,张天炀","vod_behind":"","vod_blurb":"午夜子时，血色符纸在电梯口燃尽，连接阴阳的“鬼奠梯”就此开启。 因为老宅拆迁，落魄女作家李心凌被迫回到重庆。然而，她惊恐地发现，每到午夜12点，那部废弃的电梯都会自行启动。电梯每开一次门，就有一位邻居","vod_remarks":"HD","vod_pubdate":"2026-04-04(中国大陆)","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"中国大陆","vod_lang":"汉语普通话","vod_year":"2026","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":0,"vod_hits_day":0,"vod_hits_week":0,"vod_hits_month":0,"vod_duration":"90分钟","vod_up":0,"vod_down":0,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-06-29 22:09:46","vod_time_add":1782742186,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":36994211,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vo