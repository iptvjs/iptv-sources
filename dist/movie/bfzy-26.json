hot":"","vod_actor":"八木莉可子 , 中岛裕翔","vod_director":"","vod_writer":"","vod_behind":"","vod_blurb":"作为唯一一位活跃于“时尚界最高峰”巴黎高级定制领域的日本设计师，森英惠女士终生致力于向世界传递“日本优雅”。蝴蝶主题作为象征品牌的设计风靡全球，她本人亦被亲切称为“蝴蝶夫人”。2026年正值这位英惠女士诞辰100周年。值此节点，由实力派年轻演员八木莉可子主演，将她鲜为人知的青春岁月故事搬上荧屏。 以丰富色彩与优美设计迷倒全球女性的森英惠女士，其于战后混乱期从零开始开拓设计师道路的历程却鲜为人知。本作将描绘从岛根度过的童年时光，到因亲手为孩子制衣而沉醉于西式剪裁，最终作为设计师绽放才华、进军世界的未知奋斗史","vod_remarks":"更新至高清","vod_pubdate":"2026","vod_total":0,"vod_serial":"0","vod_tv":"","vod_weekday":"","vod_area":"日本","vod_lang":"日语","vod_year":"2026","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":823,"vod_hits_day":399,"vod_hits_week":742,"vod_hits_month":445,"vod_duration":"","vod_up":858,"vod_down":326,"vod_score":"9.0","vod_score_all":4716,"vod_score_num":524,"vod_time":"2026-03-23 20:25:17","vod_time_add":1774268716,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":38079178,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"作为唯一一位活跃于“时尚界最高峰”巴黎高级定制领域的日本设计师，森英惠女士终生致力于向世界传递“日本优雅”。蝴蝶主题作为象征品牌的设计风靡全球，她本人亦被亲切称为“蝴蝶夫人”。2026年正值这位英惠女士诞辰100周年。值此节点，由实力派年轻演员八木莉可子主演，将她鲜为人知的青春岁月故事搬上荧屏。 以丰富色彩与优美设计迷倒全球女性的森英惠女士，其于战后混乱期从零开始开拓设计师道路的历程却鲜为人知。本作将描绘从岛根度过的童年时光，到因亲手为孩子制衣而沉醉于西式剪裁，最终作为设计师绽放才华、进军世界的未知奋斗史。 1926年（大正15年），英惠出生于岛根六日市村（现吉贺町），在五兄妹中排行第四。她所呈现的鲜明“色彩”与优美“形态”虽跨越时代令我们感动，但其原点据说正植根于童年熟悉的故乡原始风景。 历经战祸，22岁结婚。为给即将出生的儿子制作衣服而开始学习西...","vod_play_from":"bfzym3u8","vod_play_server":"","vod_play_note":"","vod_play_url":"高清$https:\/\/s1.fengbao9.com\/video\/senyinghuihudiezhiwai\/b9d84672ac82\/index.m3u8","vod_down_from":"","vod_down_server":"","vod_down_note":"","vod_down_url":"","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"剧情片"}]}