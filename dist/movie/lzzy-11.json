vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"<p>天才钢琴调音师尼基·怀特患有罕见的听觉过敏症，远超常人的听觉感知既是他的音乐天赋，也让他常年被周遭噪音折磨，人生困顿不前。一次偶然的机会，他意外发现自己能凭借敏锐的听觉，精准分辨锁芯转动的细微差异，仅凭声音就能破解保险箱密码。这份特殊天赋彻底改写了他的人生轨迹，他结识了深谙此道的老江湖哈里·霍洛维茨，一步步踏入高风险的盗窃世界。每一次潜入、破解、脱身都游走在危险边缘，随着行动规模不断升级，尼基的人生也在天赋与欲望的拉扯里，不断偏离原本的轨道。<\/p>","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn27.com\/20260625\/12057_d57b0678\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20260625\/12057_d57b0678\/调音师 Tuner (2025).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"剧情片"},{"vod_id":143146,"type_id":11,"type_id_1":1,"group_id":0,"vod_name":"摇滚老男孩","vod_sub":"","vod_en":"yaogunlaonanhai","vod_status":1,"vod_letter":"Y","vod_color":"","vod_tag":"","vod_class":"剧情,音乐","vod_pic":"https:\/\/img.lzipic.com\/upload\/vod\/20260625-1\/a3036b586f0118d5c8bc647e9e4d760a.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":null,"vod_actor":"王俊,张晓林,陈思桐","vod_director":"张忠和","vod_writer":"","vod_behind":"","vod_blurb":"一位得了阿兹海默症的七十岁老人，决定在还未忘记所有朋友和承诺前，回到曾经出生的城市完成少年时未完成的开一场歌唱演出的梦想。","vod_remarks":"HD","vod_pubdate":"2026-06-24(中国大陆网络)","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"中国大陆","vod_lang":"汉语普通话","vod_year":"2026","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":0,"vod_hits_day":0,"vod_hits_week":0,"vod_hits_month":0,"vod_duration":"86分钟","vod_up":0,"vod_down":0,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-06-25 10:42:19","vod_time_add":1782355339,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":38525884,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","