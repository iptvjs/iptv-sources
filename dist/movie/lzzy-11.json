_score":"7.5","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"白玫（陆小芬 饰）从小被送往别人家寄养，终因家境困顿被卖到南方澳渔港的私娼寮谋生。在那里，她被迫站在门口迎接所谓的“阿兵哥”，令人心酸的日子漫长而无奈。尽管后来养母家境好转，希望白玫改行从良，但白玫拒绝了，并毫不留情地指责他们曾出卖过她，使得家中生活变得裕盛。                                                                      　　一次偶然的火车旅途中，白玫邂逅了昔日的姊妹茵茵，她已迈向幸福，嫁给了体贴的少校，并育有一子。这幸福的场景触动了白玫内心深处的渴望，让她也开始憧憬成为一个母亲。与一位善良纯朴的渔人阿榕（马如风 饰）有了孩子后，白玫选择了离开，心生愧疚和不安。在没有告别的情况下，她独自回到了自己亲生母亲的故乡，或许是为了重新寻找自己的根与归属。这段故事充满了人生的坎坷与挣扎，展现了一个女性在逆境中的勇敢与坚韧。","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn31.com\/20260519\/6555_b79240b9\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20260519\/6555_b79240b9\/看海的日子.mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"剧情片"},{"vod_id":137149,"type_id":11,"type_id_1":1,"group_id":0,"vod_name":"吾友妻","vod_sub":"我的朋友，他的妻子 \/ My Friend &amp; His Wife","vod_en":"wuyouqi","vod_status":1,"vod_letter":"W","vod_color":"","vod_tag":"","vod_class":"剧情","vod_pic":"https:\/\/img.lzipic.com\/upload\/vod\/20260519-1\/fc7264873bb3e8b55cf627760d5253ee.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":null,"vod_actor":"朴熙顺 ,张铉诚,洪晓熙","vod_director":"申东一","vod_writer":"申东一","vod_behind":"","vod_blurb":"两个服役期间认识的男人结成深厚的友情，退伍后，一个娶了漂亮的老婆在餐厅里当三流水平却也努力向上的厨师，他在对其总是板起严厉苛求脸孔的妻子面前总是装做一幅忠诚维诺的样子，内心充满了叛逆的因子。而另一个则","vod_remarks":"HD","vod_pubdate":"2008-11-27(韩国)","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"韩国","vod_lang":"韩语","vod_year":"2008","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":0,"vod_hits_day":0,"vod_hits_week":0,"vod_hits_month":0,"v