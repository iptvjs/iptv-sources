hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":36494092,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"故事发生在20世纪90年代初，13岁的卡罗利娜是一位天赋异禀的年轻歌手，她得到了一个成为世界著名女童合唱团成员的机会，得以与她的姐姐以及其他合唱团中的竞争对手并肩而立。种种迹象表明，卡罗利娜非凡的才华已经引起了那位令人敬畏且备受赞誉的合唱团指挥的注意。这部备受期待的心理剧不仅让人联想到臭名昭著的布拉格之子合唱团事件，还让人想起其他涉及纯真与滥用权力相冲突的毁灭性情境。在一部完全没有煽情的作品中，普罗瓦兹尼克展现出了专注的谦逊和对年轻演员的非凡敏感，他描绘了一个专属的世界，在这个世界里，令人向往的声望与过早的成熟相伴而生。","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn27.com\/20260621\/11952_aa95dad2\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20260621\/11952_aa95dad2\/破碎的声线 Sbormistr (2025).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"剧情片"},{"vod_id":142341,"type_id":11,"type_id_1":1,"group_id":0,"vod_name":"被拖走的车","vod_sub":"","vod_en":"beituozoudeche","vod_status":1,"vod_letter":"B","vod_color":"","vod_tag":"","vod_class":"剧情,传记","vod_pic":"https:\/\/img.lzipic.com\/upload\/vod\/20260621-1\/8261b6ca28f54e2ae6100e0ba9454d30.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":null,"vod_actor":"萝丝·拜恩,阿丽亚娜·德博斯,柯宾·伯恩森,多米尼克·塞萨,奥克塔维亚·斯宾瑟,黛米·洛瓦托,西蒙·雷克斯,比尔·温克勒,汤姆·约翰逊,凯蒂·李·希尔,布莱尔·莱温,乌拉·尤安娜·桑切斯,邦妮·罗斯,卡罗尔·希基,艾娃·门罗·塔德罗斯,Sung Yoon,利兹·温斯坦,查德·伯里斯","vod_director":"斯蒂芬妮·莱恩","vod_writer":"乔纳森·基西,布兰特·博依文","vod_behind":"","vod_blurb":"真实故事改编，一位无家可归的西雅图妇女，在收到21634美元的拖车费后，她奋力走出拖车公司的地狱，夺回了自己的生命和汽车。","vod_remarks":"HD","vod_pubdate":"2025-06-07(翠贝卡电影节)","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"美国","vod_lang":"英语","vod_year":"2025","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod_copyright":0,"vod_points":0,"vod_points_play":0,"vod_points_down":0,"vod_hits":0,"vod_hits_da