"vod_score_all":0,"vod_score_num":0,"vod_time":"2026-04-09 04:44:14","vod_time_add":1775681054,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":38409155,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"宋真宗晚年，青春年少的包拯和好友公孙策，一同破获一起尘封多年冤案。女主角月亮十多年前，全家被奸人所害，为了翻案，打听到传闻中阴阳镜能断是非真假，于是去墓地盗取，结果触碰机关导致展昭被困，为了将其解救，必须破解地穴里的各种机关算术。一筹莫展的月亮刚好遇到聪慧过人的包拯，巧设伎俩利用鬼怪传说，想引包拯去地穴救展昭。但包拯心中秉持正义、公平，从不相信鬼怪传说，救出展昭后，月亮拿到阴阳镜后，坦白自己一家遭奸人所害的事实，凶手还在逍遥法外。为了翻案包拯，利用阴阳镜的传说，使得案件重演，凶手心绪恐惧坦白从宽，认罪伏法。从此，年少的包拯一举成名，所代表的公平、公正和正义的形象，慢慢被民众熟知，被民众所拥戴。","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn31.com\/20260409\/4665_78e3c8a2\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20260409\/4665_78e3c8a2\/阴阳镜 (2026).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":null},{"vod_id":133345,"type_id":11,"type_id_1":1,"group_id":0,"vod_name":"亚伯拉罕先生","vod_sub":"陪我走到世界尽头","vod_en":"yabolahanxiansheng","vod_status":1,"vod_letter":"Y","vod_color":"","vod_tag":"","vod_class":"剧情","vod_pic":"https:\/\/viptulz.com\/upload\/vod\/20260408-1\/e1c62d5a11d84299a0bf772562530e20.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":"","vod_actor":"Omar Sharif,伊莎贝尔·阿佳妮,伊莎贝尔·阿佳妮 Isabelle Adjani","vod_director":"François Dupeyron","vod_writer":"艾力克·埃马纽埃尔·史密特,弗朗索瓦·杜佩洪","vod_behind":"","vod_blurb":"15岁的以色列小男孩莫塞斯（                 饰）和父亲（                 饰）住在巴黎蓝色大道一幢贫穷脏乱的公寓中。母亲（                 饰）离家出","vod_remarks":"HD","vod_pubdate":"2003-09-17(法国)","vod_total":0,"vod_serial":"","vod_tv":"","vod_weekday":"","vod_area":"法国","vod_lang":"法语,土耳其语","vod_year":"2003","vod_version":"","vod_state":"","vod_author":"","vod_jumpurl":"","vod_tpl":"","vod_tpl_play":"","vod_tpl_down":"","vod_isend":0,"vod_lock":0,"vod_level":0,"vod