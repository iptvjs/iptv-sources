_down":0,"vod_hits":0,"vod_hits_day":0,"vod_hits_week":0,"vod_hits_month":0,"vod_duration":"98分钟","vod_up":0,"vod_down":0,"vod_score":"0.0","vod_score_all":0,"vod_score_num":0,"vod_time":"2026-05-06 03:43:06","vod_time_add":1778010186,"vod_time_hits":0,"vod_time_make":0,"vod_trysee":0,"vod_douban_id":36901130,"vod_douban_score":"0.0","vod_reurl":"","vod_rel_vod":"","vod_rel_art":"","vod_pwd":"","vod_pwd_url":"","vod_pwd_play":"","vod_pwd_play_url":"","vod_pwd_down":"","vod_pwd_down_url":"","vod_content":"2013年，一名离60岁还有几个月的澳大利亚男子决定走圣地亚哥之路——一条横跨西班牙山顶的800公里朝圣之路。他没有宗教信仰，也完全不知道为什么他如此强烈地被迫走这条痛苦的路。但他是被迫的。他完成了步行，与“三重疼痛”作斗争——他后来发现膝盖缺乏任何有意义的软骨，一看到水泡就会让一个成年人哭泣，胫骨酸痛感觉就像他的下肢被一个疯狂的巨魔挥舞的山斧劈开了。当他到达圣地亚哥德孔波斯特拉雄伟的大教堂卡米诺的尽头时，他期待着一个顿悟——一个他每天都在问自己的问题的答案：我为什么要这样做？但没有人回答。所以当他回到家时，他写了一本书，希望答案能在他的涂鸦中显现出来。结果就是《路，我的路》，这是一本幽默而自嘲的书，许多人认为这是有史以来关于走过卡米诺的最好的回忆录。这本书现在已经拍成了一部电影，它非同寻常地描述了一个男人在人生的关键时刻，寻找意义，发现自己正在经历一场深刻的根本性转变，以至于他现在将自己的生活分为“卡米诺之前”和“卡米诺之后”。这是一个男人特有的故事，但对任何寻求生命更大意义的人都有吸引力。","vod_play_from":"lzm3u8","vod_play_server":"no","vod_play_note":"","vod_play_url":"HD中字$https:\/\/v.lzcdn31.com\/20260506\/6187_a5a77a1f\/index.m3u8","vod_down_from":"http","vod_down_server":"no","vod_down_note":"","vod_down_url":"HD中字$https:\/\/dow.lzdown28.com\/20260506\/6187_a5a77a1f\/我的朝圣之路 The Way, My Way (2024).mp4","vod_plot":0,"vod_plot_name":"","vod_plot_detail":"","type_name":"喜剧片"},{"vod_id":135681,"type_id":7,"type_id_1":1,"group_id":0,"vod_name":"趣塔德庄园","vod_sub":"趣塔德大厅","vod_en":"qutadezhuangyuan","vod_status":1,"vod_letter":"Q","vod_color":"","vod_tag":"","vod_class":"喜剧","vod_pic":"https:\/\/viptulz.com\/upload\/vod\/20260502-1\/070525cc0cde6cd4a5aff11381ea25e2.webp","vod_pic_thumb":"","vod_pic_slide":"","vod_pic_screenshot":null,"vod_actor":"戴米恩·路易斯,凯瑟琳·沃特斯顿,托马辛·麦肯齐,本·拉德克利夫,汤姆·费尔顿,艾玛·莱尔德,李·布罗德曼,汤姆·古德曼-希尔,吉米·卡尔,莉莉·奈特,亚当·伍德沃德,查理·罗尔斯,卢卡斯·凯利,内森·霍尔,亚历山大·巴特勒,莉兹·霍普利,艾琳·奥斯汀,玛格达莱娜·斯维兰德,杰玛·瓦德尔,劳瑞·奥格登","vod_director":"吉姆·奥汉龙","vod_writer":"吉米·卡尔,帕特里克·卡尔,安德鲁·道森,斯蒂夫·道森,蒂姆·因曼","vod_behind":"","vod_blurb":"对传统的时期剧如《唐顿